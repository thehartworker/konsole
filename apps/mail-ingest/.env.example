# apps/mail-ingest Env-Vars. NIEMALS echte Werte committen (AGENTS.md §4).
# Produktions-Datei liegt unter /etc/konsole/mail-ingest.env auf dem
# Hetzner-Host, siehe docs/ops/mail-ingest-deployment.md.

# Supabase (Service-Role, RLS-Bypass -- siehe
# docs/decisions/2026-07-10_rls-policies.md, "Konsequenzen").
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Für den Klassifikations-Aufruf nach dem Vorgangs-Insert (packages/persistence).
ANTHROPIC_API_KEY=

# Muss exakt dem Wert entsprechen, den apps/web für dieselbe Umgebung nutzt
# (sonst können Modus-B-Passwörter, die dort verschlüsselt wurden, hier
# nicht mehr entschlüsselt werden). Erzeugen mit: openssl rand -hex 32.
# Siehe docs/ops/imap-verschluesselung.md.
IMAP_PASSWORT_VERSCHLUESSELUNGS_SCHLUESSEL=

# Modus A: geteilter Zugang zum Konsolen-Postfach. Nur nötig, wenn
# mindestens eine weiterleitung-Anbindung aktiv ist (siehe env.ts,
# pruefeKonsolenPostfachEnv).
KONSOLEN_POSTFACH_IMAP_HOST=imap.mailbox.org
KONSOLEN_POSTFACH_IMAP_PORT=993
KONSOLEN_POSTFACH_IMAP_USER=
KONSOLEN_POSTFACH_IMAP_PASS=

# Health-Endpoint (Uptime-Robot, systemd), siehe health-server.ts.
HEALTH_PORT=3001

# Fallback-Poll-Intervall, falls eine IDLE-Verbindung still gestorben ist.
FALLBACK_POLL_INTERVALL_MS=300000

# pino-Log-Level: fatal|error|warn|info|debug|trace|silent.
LOG_LEVEL=info
