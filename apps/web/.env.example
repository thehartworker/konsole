# Supabase-Projekt-Zugangsdaten fuer lokale Entwicklung.
# NIEMALS echte Werte committen (AGENTS.md §4, "Keine Secrets im Code").
# Diese Datei nach .env.local kopieren und dort ausfuellen.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nur serverseitig verwenden (Admin-API fuer Nutzer-Anlage), niemals im
# Client-Bundle referenzieren oder mit NEXT_PUBLIC_-Praefix versehen.
# Siehe docs/decisions/2026-07-11_basis-auth.md.
SUPABASE_SERVICE_ROLE_KEY=

# Nur serverseitig (Server-Actions), fuer den scharfen W1/W2-Handler-Aufruf
# aus der Vorgangs-Detailansicht (Issue #43). Siehe
# docs/decisions/2026-07-13_konsole-block1-vorgangs-detailansicht.md.
ANTHROPIC_API_KEY=

# E-Mail-Kanal (Issue #52). Muss exakt dem Wert entsprechen, den
# apps/mail-ingest fuer dieselbe Umgebung nutzt (siehe
# docs/ops/imap-verschluesselung.md) -- diese App verschluesselt beim
# Einrichten einer Modus-B-Anbindung, apps/mail-ingest entschluesselt beim
# Verbindungsaufbau.
IMAP_PASSWORT_VERSCHLUESSELUNGS_SCHLUESSEL=

# Modus A (Weiterleitung, Aufgabe D/E): SMTP-Zugang fuer den Bestaetigungs-
# Testmail-Versand aus testeKonsolenPostfachEintreffen (nodemailer). Kann
# derselbe Provider wie das Konsolen-Postfach sein (z. B. mailbox.org SMTP-
# Submission), muss aber nicht -- irgendein SMTP-Absender reicht, solange die
# Test-Mail beim Konsolen-Postfach ankommt.
KONSOLEN_TEST_SMTP_HOST=
KONSOLEN_TEST_SMTP_PORT=587
KONSOLEN_TEST_SMTP_USER=
KONSOLEN_TEST_SMTP_PASS=
KONSOLEN_TEST_SMTP_ABSENDER=

# Domain-Teil der generierten Plus-Adressen fuer Modus A, z. B.
# "mensch-betrieb+neurabin-pharma@<diese-domain>". Muss auf das
# Konsolen-Postfach zeigen (MX/Weiterleitung dorthin), Betriebs-Entscheidung
# ausserhalb dieses Codes.
MAIL_INTAKE_DOMAIN=intake.example.de
